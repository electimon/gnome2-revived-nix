From 88a2d8b008f246d0535073ef1adb172d100227ba Mon Sep 17 00:00:00 2001
From: Stella Diaz <electi@yzu.moe>
Date: Mon, 9 Mar 2026 18:34:32 -0400
Subject: [PATCH] graaa

---
 gconf/gconf-internals.h    | 2 +-
 gconf/gconf-sanity-check.c | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/gconf/gconf-internals.h b/gconf/gconf-internals.h
index abb641b..d4baf60 100644
--- a/gconf/gconf-internals.h
+++ b/gconf/gconf-internals.h
@@ -39,7 +39,7 @@
 #include "GConfX.h"
 
 #undef GCONF_CONFDIR
-#define GCONF_CONFDIR "/etc/gconf"
+#define GCONF_CONFDIR "/etc/gconf/2"
 
 #ifdef G_OS_WIN32
 
diff --git a/gconf/gconf-sanity-check.c b/gconf/gconf-sanity-check.c
index 5d7caa1..ed2ad9f 100644
--- a/gconf/gconf-sanity-check.c
+++ b/gconf/gconf-sanity-check.c
@@ -65,7 +65,7 @@ main (int argc, char** argv)
   if (!check_file_locking ())
     return 1;
 
-  if (!check_gconf (FALSE))
+  if (!check_gconf (TRUE))
     {
       if (!offer_delete_locks ())
         return 1;
